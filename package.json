{
  "name": "@co6tter/vite-lib-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/co6tter/vite-lib-app.git"
  },
  "version": "1.1.6",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/my-lib.umd.cjs",
  "module": "./dist/my-lib.js",
  "types": "./dist/my-lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/my-lib.js",
